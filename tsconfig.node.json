{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "composite": true,  // Ensure this is here
    "moduleResolution": "node",
    "isolatedModules": true
  },
  "include": ["src"]
}
